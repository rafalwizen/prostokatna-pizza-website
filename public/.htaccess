# ProstoKątna — home.pl / Apache config
# gzip + long-lived immutable cache for static assets + security headers.
# Every block is guarded with <IfModule> so a missing module degrades
# silently instead of returning HTTP 500.

# ===== Compression (mod_deflate) =====
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json image/svg+xml
  AddOutputFilterByType DEFLATE application/xml RSS
</IfModule>

# ===== Cache expiration (mod_expires) =====
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML: always revalidate
  ExpiresByType text/html "access plus 0 seconds"
  # 1 year immutable for static assets
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresDefault "access plus 1 year"
</IfModule>

# ===== Security headers (mod_headers) =====
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # Immutable hint for hashed static assets
  <FilesMatch "\.(css|js|avif|webp|png|jpg|jpeg|svg|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
