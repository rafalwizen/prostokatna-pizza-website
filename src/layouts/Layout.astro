---
import "@/styles/global.css";
import type { Lang } from "@/i18n/config";
import {
  SITE_URL,
  localizedUrl,
  hreflangMap,
} from "@/i18n/config";
import { business, buildJsonLd } from "@/data/business";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Per-language SEO copy. PL ported verbatim from the source metadata; EN written
// as an equivalent. Description drives <meta description>, OG and Twitter.
const seoByLang: Record<Lang, {
  title: string;
  ogTitle: string;
  description: string;
  keywords: string;
  ogLocale: string;
}> = {
  pl: {
    title: "Pizza Tarnowskie Góry | ProstoKątna — pizzeria, dostawa",
    ogTitle: "ProstoKątna — pizza Tarnowskie Góry | pizzeria ul. Zamkowa, dostawa",
    description: business.description,
    keywords:
      "pizza Tarnowskie Góry, pizzeria Tarnowskie Góry, dostawa pizzy Tarnowskie Góry, pizza na wynos Tarnowskie Góry, włoska kuchnia, ProstoKątna, ul. Zamkowa 6, Slice Pizza TG",
    ogLocale: "pl_PL",
  },
  en: {
    title: "Pizza Tarnowskie Góry | ProstoKątna — pizzeria, delivery",
    ogTitle: "ProstoKątna — pizza Tarnowskie Góry | pizzeria, delivery",
    description:
      "ProstoKątna pizzeria in Tarnowskie Góry — authentic Italian flavors, pizza made with heart. ul. Zamkowa 6. Order delivery or takeaway: +48 722 720 000.",
    keywords:
      "pizza Tarnowskie Góry, pizzeria Tarnowskie Góry, pizza delivery Tarnowskie Góry, pizza takeaway Tarnowskie Góry, Italian cuisine, ProstoKątna, Slice Pizza TG",
    ogLocale: "en_US",
  },
};

const seo = seoByLang[lang];
const canonical = localizedUrl(lang);
const ogImage = `${SITE_URL}/logo-opengraph-v2.png`;
const jsonLd = buildJsonLd(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="keywords" content={seo.keywords} />
    <meta name="author" content={business.name} />
    <meta name="robots" content="index,follow" />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="pl" href={hreflangMap.pl} />
    <link rel="alternate" hreflang="en" href={hreflangMap.en} />
    <link rel="alternate" hreflang="x-default" href={hreflangMap["x-default"]} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={seo.ogTitle} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={business.name} />
    <meta property="og:locale" content={seo.ogLocale} />
    <meta property="og:site_name" content={business.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Geo meta — local SEO signals -->
    <meta name="geo.region" content="PL-SL" />
    <meta name="geo.placename" content="Tarnowskie Góry" />
    <meta
      name="geo.position"
      content={`${business.geo.latitude};${business.geo.longitude}`}
    />
    <meta name="ICBM" content={`${business.geo.latitude}, ${business.geo.longitude}`} />

    <!-- Font preloads (CORS required for fonts) -->
    <link
      rel="preload"
      href="/fonts/BadRendezvousScript.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/SpaceMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/SpaceMono-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link rel="icon" href="/favicon.ico" sizes="any" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <div class="min-h-screen">
      <slot />
    </div>
  </body>
</html>
