---
import type { Lang } from "@/i18n/config";
import { t } from "@/i18n/ui";
import { delivery } from "@/data/business";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<div class="mb-16">
  <h2 class="text-5xl md:text-6xl font-bold font-space-mono-bold text-center text-[#ff8d2f] mb-16">
    {t(lang, "orderTitle")}
  </h2>

  <div class="flex flex-col md:flex-row gap-6 md:gap-12 justify-center items-center w-full">
    {
      delivery.map((option) => (
        <a
          href={option.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 w-full max-w-xs md:w-auto hover:opacity-80 transition"
        >
          <img
            src={option.icon}
            alt={option.name}
            width="48"
            height="48"
            loading="lazy"
            decoding="async"
            class="w-12 h-12"
          />
          <span class="text-lg text-gray-300 font-space-mono-regular">{option.name}</span>
        </a>
      ))
    }
  </div>
</div>
