---
import type { Lang } from "@/i18n/config";
import { t } from "@/i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<section id="about" class="py-20 bg-black">
  <div class="container mx-auto px-4 max-w-3xl text-center">
    <h2 class="text-4xl md:text-5xl font-bold font-space-mono-bold text-[#ff8d2f] mb-8">
      {t(lang, "aboutTitle")}
    </h2>
    <p class="text-lg md:text-xl text-gray-300 leading-relaxed font-space-mono-regular">
      {t(lang, "aboutText")}
    </p>
  </div>
</section>
